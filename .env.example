# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack — Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...

# Slack — App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-...

# Source layer root — defaults to Thomas' Drive sync mount on macOS.
# Override on any other machine, server, or CI runner.
# AINSTEIN_SOURCE_ROOT=/path/to/your/Drive/AInstein

# --- Google Drive API mode (required for server/VM deployment) ---
# Service account JSON as a single-line string (no embedded newlines).
# IMPORTANT: The service account must use drive.file scope (not drive scope)
# and must be explicitly shared ONLY on the Minkowski AInstein folder in Drive.
# Never commit this value to git.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ID of the Minkowski AInstein root folder in Drive.
# Default: 1ziMd8Zmhgpqq_iHyoz3-59_KwL7kbm7e
# AINSTEIN_DRIVE_ROOT_ID=1ziMd8Zmhgpqq_iHyoz3-59_KwL7kbm7e

# Optional: Slack channel ID where Ainstein posts startup/crash notifications.
# Set to a private channel like #ainstein-status so you're notified if the bot
# goes down or restarts unexpectedly. Leave empty to disable.
# AINSTEIN_STATUS_CHANNEL=C0XXXXXXXXX
