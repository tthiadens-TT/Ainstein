# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack — Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...

# Slack — App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-...

# Source layer root — defaults to Thomas' Drive sync mount on macOS.
# Override on any other machine, server, or CI runner.
# AINSTEIN_SOURCE_ROOT=/path/to/your/Drive/AInstein

# --- Google Drive API mode (required for server/VM deployment) ---
# Service account JSON as a single-line string (no embedded newlines).
# IMPORTANT: The service account must have the full 'drive' scope (not drive.file)
# and must be granted Contributor access on the Minkowski AInstein Shared Drive.
# Never commit this value to git.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Alternatively: path to the service account JSON key file on disk.
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/ainstein-bot-key.json

# ID of the Minkowski AInstein Workspace Shared Drive root folder.
# Default: 0AFvBEDYKrnHbUk9PVA (Workspace Shared Drive "Minkowski AInstein")
# AINSTEIN_DRIVE_ROOT_ID=0AFvBEDYKrnHbUk9PVA

# ID of the shared Google Doc used by save_note to store working notes.
# Create a Google Doc in 00_Werkdocumenten, share it with the service account
# (Editor), then paste the document ID here (from the URL: /d/<ID>/edit).
# Without this variable, save_note falls back to a local .md file which does
# not exist on the VM — notes will be silently lost.
# AINSTEIN_NOTES_DOC_ID=1abc...xyz

# Optional: Slack channel ID where Ainstein posts startup/crash notifications.
# Set to a private channel like #ainstein-status so you're notified if the bot
# goes down or restarts unexpectedly. Leave empty to disable.
# AINSTEIN_STATUS_CHANNEL=C0XXXXXXXXX

# Optional: maximum Slack invocations per user per hour (default: 10).
# Raise this for power users, lower it to protect API costs.
# RATE_LIMIT_MAX=10

# Optional: Tavily API key for web search (https://tavily.com — free tier: 1.000 searches/maand).
# Als ingesteld: Ainstein gebruikt Tavily voor rijkere, betrouwbaardere zoekresultaten.
# Als leeg: fallback naar DuckDuckGo (minder betrouwbaar).
# TAVILY_API_KEY=tvly-...

# --- Jamie webhook integratie ---
# Shared secret for HMAC-SHA256 signature verification.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Configure the same value in Jamie's webhook settings.
# Leave unset to disable the webhook server entirely.
# JAMIE_WEBHOOK_SECRET=

# Port for the Flask webhook server (default: 8080).
# Nginx should proxy /webhooks/ to http://127.0.0.1:<port>/webhooks/
# JAMIE_WEBHOOK_PORT=8080

# Optional: Slack channel ID for error/parse-failure notifications from the webhook server.
# Ainstein resolves participant Slack IDs dynamically via users.lookupByEmail —
# no staff mapping needed. This channel is only used as a fallback for errors.
# Requires users:read.email OAuth scope on the Slack app.
# AINSTEIN_TRANSCRIPT_CHANNEL=C0XXXXXXXXX

# Optional: Jamie API key for fetching transcripts if not included in the webhook payload.
# JAMIE_API_KEY=
