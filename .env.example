# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack — Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...

# Slack — App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-...

# Source layer root — defaults to Thomas' Drive sync mount on macOS.
# Override on any other machine, server, or CI runner.
# AINSTEIN_SOURCE_ROOT=/path/to/your/Drive/AInstein
