# Git LFS — large binary proposals
# Requires: brew install git-lfs && git lfs install (run once per clone)
01_Proposals/**/*.pdf filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text

# Line endings
*.py text eol=lf
*.md text eol=lf
